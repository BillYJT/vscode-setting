{
    "vim.normalModeKeyBindings": [
        {
            "before" : ["<leader>","e"],
            "commands" : [
                "workbench.view.explorer"
            ]
        },
        {
            "before" : ["<leader>","f"],
            "commands" : [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before" : ["<leader>","o"],
            "commands" : [
                "outline.focus",
                "outline.collapse"
            ]
        },
        // big up/down move
        {
            "before" : ["<leader>","j"],
            "commands" : [
                "editor.action.joinLines"
            ]
        },
        {
            "before": ["<leader>","b"],
            "commands": ["workbench.action.toggleSidebarVisibility"]
        },
        {
            "before" : ["J"],
            "after" : [
                "5","j"
            ]
        },
        {
            "before" : ["K"],
            "after" : [
                "5","k"
            ]
        },
        // view scroll without moving cursor
        {
            "before": ["<C-j>"],
            "after": ["5", "<C-e>"]
        },
        {
            "before": ["<C-k>"],
            "after": ["5", "<C-y>"]
        },
    ],
    "vim.leader": " ",

}
